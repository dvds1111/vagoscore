# ─── VagoScore — Variables de entorno ───────────────────────────────
# Copia este archivo a ".env" y pon tu clave real.
# El archivo ".env" NUNCA sube a GitHub (está en .gitignore).

# Tu clave de API-Football
APIFOOTBALL_KEY=pega_tu_clave_aqui

# Host de la API:
#   - Si la sacaste de api-football.com (directo):  v3.football.api-sports.io
#   - Si la sacaste de RapidAPI:                    api-football-v1.p.rapidapi.com
APIFOOTBALL_HOST=v3.football.api-sports.io
